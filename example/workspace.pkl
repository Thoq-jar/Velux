amends "../pkl/WorkspaceConfig.pkl"

local commonScripts = Map(
  "clean", new Script {
    name = "clean"
    command = "rm -rf build/ dist/ *.tmp src/*/build tests/build velux-out/"
    description = "Clean all build artifacts"
  },
  "format", new Script {
    name = "format"
    command = "find src tests -name '*.c' -o -name '*.h' | xargs clang-format -i"
    description = "Format all source code"
  },
  "test", new Script {
    name = "test"
    command = "DYLD_LIBRARY_PATH=../velux-out/shared ./velux-out/executable/test_runner"
    description = "Run all tests"
    workingDir = "."
  },
  "run", new Script {
    name = "run"
    command = "DYLD_LIBRARY_PATH=./velux-out/shared ./velux-out/executable/velux-app"
    description = "Run the main application"
    workingDir = "."
  }
)

workspace = new Workspace {
  name = "VeluxDemo"
  version = "1.0.0"
  scripts = commonScripts
  projects = Map(
    "build", new Project {
      name = "build"
      path = "."
      type = "executable"
      buildConfig = "**/*.pkl"
    },
    "core", new Project {
      name = "core"
      path = "src/core"
      type = "library"
      buildConfig = "core.pkl"
    },
    "app", new Project {
      name = "app"
      path = "src/app"
      type = "executable"
      dependencies = List("core")
      buildConfig = "app.pkl"
    },
    "tests", new Project {
      name = "tests"
      path = "tests"
      type = "test"
      dependencies = List("core")
      buildConfig = "tests.pkl"
    }
  )
  environments = Map(
    "dev", new Environment {
      name = "dev"
      variables = Map("LOG_LEVEL", "debug", "ENABLE_PROFILING", "true")
      features = Set("debug-ui", "verbose-logging")
    },
    "prod", new Environment {
      name = "prod"
      variables = Map("LOG_LEVEL", "info", "OPTIMIZE", "true")
    }
  )
  configFiles = Map(
    "git", ".gitignore",
    "editor", ".editorconfig"
  )
}